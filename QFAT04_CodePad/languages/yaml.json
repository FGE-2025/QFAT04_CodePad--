{
  "default_name": "YAML",
  "base": "text",
  "extensions": [
    "yml",
    "yaml"
  ],
  "comment_prefixes": [
    "#"
  ],
  "case_sensitive": true,
  "builtin": true,
  "keywords": [
    "true",
    "false",
    "null",
    "yes",
    "no",
    "on",
    "off"
  ],
  "keyword_groups": [
    "true\nfalse\nnull\nyes\nno\non\noff",
    "",
    "",
    "",
    "",
    ""
  ],
  "keyword_group_styles": [
    "keyword1",
    "keyword2",
    "keyword3",
    "keyword4",
    "keyword5",
    "keyword6"
  ],
  "prefix_modes": [
    false,
    false,
    false,
    false,
    false,
    false
  ],
  "variable_patterns": [],
  "operators1": ": - > | >>",
  "delimiters": [
    {
      "open": "\"",
      "escape": "\\",
      "close": "\""
    },
    {
      "open": "'",
      "escape": "'",
      "close": "'"
    }
  ],
  "folding": {}
}